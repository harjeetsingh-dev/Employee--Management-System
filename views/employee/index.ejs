<%- include('../components/head.ejs', { title: "All Employees" }) %>
    <%- include('../components/navbar.ejs') %>
        <body class="bg-gray-100 min-h-screen">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

                <!-- Page Header -->
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-800">
                            Employee Management
                        </h1>
                        <p class="text-gray-500 mt-1">
                            Manage all employee records from here.
                        </p>
                    </div>

                    <a href="/employee/new"
                        class="inline-block bg-blue-600 text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-blue-700 transition text-center">
                        + Add New Employee
                    </a>
                </div>

                <!-- Total Employees Card -->
                <div class="bg-white rounded-xl shadow-sm p-5 mb-6 border border-gray-200">
                    <p class="text-gray-500 text-sm">Total Employees</p>
                    <h2 class="text-2xl font-bold text-gray-1000">
                        <%= employees.length %>
                    </h2>
                </div>

                <!-- Table Card -->
                <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">

                    <!-- Scroll Wrapper -->
                    <div class="overflow-x-auto">

                        <table class="min-w-full text-sm text-left">

                            <thead class="bg-gray-800 text-white">
                                <tr>
                                    <th class="px-6 py-4 font-semibold whitespace-nowrap">Name</th>
                                    <th class="px-6 py-4 font-semibold whitespace-nowrap">Email</th>
                                    <th class="px-6 py-4 font-semibold whitespace-nowrap">Department</th>
                                    <th class="px-6 py-4 font-semibold whitespace-nowrap">Position</th>
                                    <th class="px-6 py-4 font-semibold whitespace-nowrap">Salary</th>
                                    <th class="px-6 py-4 font-semibold whitespace-nowrap text-center">Actions</th>
                                </tr>
                            </thead>

                            <tbody class="divide-y divide-gray-200">
                                <% for (let employee of employees) { %>
                                    <tr class="hover:bg-gray-50 transition">

                                        <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-800">
                                            <%= employee.username %>
                                        </td>

                                        <td class="px-6 py-4 whitespace-nowrap text-gray-600">
                                            <%= employee.email %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-gray-600">
                                            <%= employee.department %>
                                        </td>

                                        <td class="px-6 py-4 whitespace-nowrap text-gray-600">
                                            <%= employee.position %>
                                        </td>

                                        <td class="px-6 py-4 whitespace-nowrap text-gray-700 font-medium">
                                            ₹&nbsp;<%= employee.salary %>
                                        </td>

                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="flex items-center justify-center gap-2">

                                                <!-- View Button -->
                                                <!-- <a href="/employee/:<%=employee._id %>"
                                                    class="bg-green-500 text-white px-3 py-1.5 rounded-md hover:bg-green-600 transition text-sm">
                                                    View
                                                </a> -->
                                                <span class="text-gray-300">|</span>

                                                <!-- Edit Button -->
                                                <a href="/employee/<%=employee._id %>/edit"
                                                    class="bg-yellow-500 text-white px-3 py-1.5 rounded-md hover:bg-yellow-600 transition text-sm">
                                                    Edit
                                                </a>

                                                <span class="text-gray-300">|</span>

                                                <!-- Delete Button -->
                                                <form action="/employee/<%=employee._id %>/delete?_method=DELETE"
                                                    method="POST" class="inline">
                                                    <button type="submit"
                                                        class="bg-red-500 text-white px-3 py-1.5 rounded-md hover:bg-red-600 transition text-sm">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>

                                    </tr>
                                    <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </body>

        </html>